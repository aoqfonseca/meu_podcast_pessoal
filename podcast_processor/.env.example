# --- LLM (text generation) ---
# Required when PODCAST_LLM_PROVIDER=gemini (default)
GOOGLE_API_KEY=your-key-here

# Required when PODCAST_LLM_PROVIDER=groq (free tier — get one at https://console.groq.com)
# GROQ_API_KEY=gsk_...

# --- Optional overrides ---
# LLM provider: gemini | groq
# PODCAST_LLM_PROVIDER=gemini
# PODCAST_TEXT_MODEL=gemini-2.5-flash-lite
# PODCAST_GROQ_MODEL=llama-3.3-70b-versatile

# TTS provider: edge (free, default) | gemini (paid, needs GOOGLE_API_KEY)
# PODCAST_TTS_PROVIDER=edge
# PODCAST_EDGE_TTS_VOICE=pt-BR-FranciscaNeural
# PODCAST_TTS_MODEL=gemini-2.5-flash-preview-tts
# PODCAST_TTS_VOICE=Kore

# Embeddings
# PODCAST_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
