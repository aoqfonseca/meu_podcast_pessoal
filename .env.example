# =============================================================================
# meu-podcast-pessoal — environment variables
# Copy this file to .env and fill in the values you need.
# docker-compose and run-all.sh both load .env from the repo root automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API keys — only the key for your chosen provider is required.
# -----------------------------------------------------------------------------

# Required when PODCAST_LLM_PROVIDER=gemini (default).
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Alias accepted in place of GOOGLE_API_KEY (either one is fine).
# GEMINI_API_KEY=

# Required when PODCAST_LLM_PROVIDER=groq (free tier).
# Get one at https://console.groq.com
# GROQ_API_KEY=

# -----------------------------------------------------------------------------
# LLM provider & model
# -----------------------------------------------------------------------------

# gemini (default) | groq
# PODCAST_LLM_PROVIDER=gemini

# Gemini model used for text generation.
# PODCAST_TEXT_MODEL=gemini-2.5-flash-lite

# Groq model used when PODCAST_LLM_PROVIDER=groq.
# PODCAST_GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# TTS provider & voice
# -----------------------------------------------------------------------------

# edge (default, free, no key needed) | gemini (paid, needs GOOGLE_API_KEY)
# PODCAST_TTS_PROVIDER=edge

# Edge TTS voice (used when PODCAST_TTS_PROVIDER=edge).
# PODCAST_EDGE_TTS_VOICE=pt-BR-FranciscaNeural

# Gemini TTS model and voice (used when PODCAST_TTS_PROVIDER=gemini).
# PODCAST_TTS_MODEL=gemini-2.5-flash-preview-tts
# PODCAST_TTS_VOICE=Kore

# -----------------------------------------------------------------------------
# Embeddings (FAISS / RAG)
# -----------------------------------------------------------------------------

# PODCAST_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# -----------------------------------------------------------------------------
# Pipeline control (can also be passed as CLI flags to run-all.sh)
# -----------------------------------------------------------------------------

# Extra flags forwarded to `leitor_links fetch`.
# FETCH_ARGS=--tags IA,Rust --since-days 7

# Extra flags forwarded to `podcast-processor run`.
# PROCESS_ARGS=--skip-audio --minutes 10

# Steps to run: fetch,process (default: both).
# STEPS=fetch,process
